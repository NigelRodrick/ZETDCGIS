{
  "name": "meter-collect-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas:android": "npx eas-cli@16 build --platform android --profile android-apk",
    "eas:ios": "npx eas-cli@16 build --platform ios --profile ios-ipa",
    "prebuild:android": "expo prebuild --platform android"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "^52.0.0",
    "expo-location": "~18.0.10",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  },
  "overrides": {
    "@xmldom/xmldom": "0.9.10",
    "expo-file-system": {
      "expo": "52.0.49"
    }
  }
}
